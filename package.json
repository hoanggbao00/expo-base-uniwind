{
  "name": "expo-base-uniwind",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "addons/*"
  ],
  "scripts": {
    "start": "bun --cwd apps/native start",
    "android": "bun --cwd apps/native android",
    "typecheck": "bun --cwd apps/native typecheck",
    "ios": "bun --cwd apps/native ios",
    "prebuild:all": "bun --cwd apps/native prebuild:all",
    "prebuild:android": "bun --cwd apps/native prebuild:android",
    "prebuild:ios": "bun --cwd apps/native prebuild:ios",
    "build:apk": "bun --cwd apps/native build:apk",
    "build:aab": "bun --cwd apps/native build:aab",
    "expo": "bun --cwd apps/native expo",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install",
    "addons:sentry": "bun --cwd addons/sentry setup"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "lefthook": "^2.0.16",
    "ultracite": "7.1.1"
  },
  "catalog": {
    "expo": "~55.0.17",
    "expo-router": "~55.0.13",
    "@sentry/react-native": "^8.8.0",
    "react": "19.2.0",
    "@types/react": "~19.2.2",
    "react-native": "0.83.6",
    "zustand": "5.0.12",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react": "19.2.0",
    "react-native": "0.83.6"
  }
}
