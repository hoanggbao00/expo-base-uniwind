{
  "name": "Expo Dev Container",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installGradle": "true"
    },
    "ghcr.io/CASL0/devcontainer-features/android-sdk:1": {
      "platformsVersion": "36",
      "buildToolsVersion": "36.0.0",
      "installNdk": true,
      "ndkVersion": "28.0.12674087",
      "installCmake": true,
      "cmakeVersion": "3.22.1"
    }
  },
  "containerEnv": {
    "ADB_SERVER_SOCKET": "tcp:host.docker.internal:5037",
    "GRADLE_OPTS": "-Dorg.gradle.vfs.watch=false -Dorg.gradle.daemon=false"
  },
  "mounts": [
    // Cache for node_modules specific to this project
    "source=node_modules_${localWorkspaceFolderBasename}_${devcontainerId},target=${containerWorkspaceFolder}/node_modules,type=volume",

    // Cache for global
    "source=gradle_cache,target=/home/node/.gradle,type=volume",
    "source=bun_cache,target=/home/node/.bun/install/cache,type=volume",

    // Android SDK Bind: Use the local Android SDK installed on the host machine
    "source=${localEnv:HOME}/.android,target=/home/node/.android,type=bind"
  ],

  "forwardPorts": [8081],
  "postCreateCommand": "bash ./.devcontainer/post-create-command.sh",
  "remoteUser": "node",

  "customizations": {
    "vscode": {
      "settings": {
        "typescript.tsdk": "node_modules/typescript/lib",
        "javascript.preferences.importModuleSpecifier": "non-relative",
        "typescript.preferences.importModuleSpecifier": "non-relative",

        // Biome
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.biome": "explicit",
          "source.organizeImports.biome": "explicit"
        },
        "[typescript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[json]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[css]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[markdown]": {
          "editor.defaultFormatter": "biomejs.biome"
        },

        // Tailwind CSS
        "tailwindCSS.classFunctions": ["tw", "clsx", "tw\\.[a-z-]+", "cn"],

        // I18n Ally
        "i18n-ally.localesPaths": [
          "apps/native/src/i18n",
          "apps/native/src/i18n/locales"
        ],
        "i18n-ally.sortKeys": true,
        "i18n-ally.keepFulfilled": true
      },
      "extensions": [
        "biomejs.biome",
        "expo.vscode-expo-tools",
        "bradlc.vscode-tailwindcss",
        "streetsidesoftware.code-spell-checker",
        "aaron-bond.better-comments",
        "lokalise.i18n-ally",
        "blazejkustra.react-compiler-marker",
        "BriteSnow.vscode-toggle-quotes",
        "dsznajder.es7-react-js-snippets"
      ]
    }
  }
}
